CLIENTID="${CLIENTID:-opentdf}"
CLIENTSECRET="${CLIENTSECRET:-secret}"
KCHOST="${KCHOST:-http://localhost:8888}"
REALM="${REALM:-opentdf}"
KCFULLURL="${KCFULLURL:-$KCHOST/auth/realms/$REALM}"
TOKENENDPOINT="${TOKENENDPOINT:-$KCFULLURL/protocol/openid-connect/token}"
PLATFORMENDPOINT="${PLATFORMENDPOINT:-localhost:8080}"
PLATFORMURL="${PLATFORMURL:-http://$PLATFORMENDPOINT}"
KASURL="${KASURL:-http://$PLATFORMENDPOINT/kas}"
